rules_version = '2';

// Phase 3a/3b rules — covers /users (+ friends/ruleSets subcollections),
// /rooms (+ actions/events/messages subcollections), /friendRequests,
// /blocks, /conversations (+ messages), /gameInvites, /reports per
// docs/GAME_SPEC.md §L.
//
// Known gap: room-doc updates aren't yet restricted by field, so a non-host
// player could in principle write `gameState` via the `update` rule below
// (which only checks membership, not which fields changed). Tightening this
// with `request.resource.data.diff(resource.data).affectedKeys()` is a
// follow-up hardening item before production traffic.
//
// Known gap: /users/{uid}/friends/{friendUid} allows either side of a
// friendship to write either party's subcollection entry, since accepting a
// friend request writes both `/users/{fromUid}/friends/{toUid}` and
// `/users/{toUid}/friends/{fromUid}` from a single client in one batch. This
// mirrors the room-update gap above as a deliberate, narrow relaxation.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      match /friends/{friendUid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null
          && (request.auth.uid == uid || request.auth.uid == friendUid);
      }

      match /ruleSets/{ruleSetId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /blocks/{uid}/blocked/{targetUid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /friendRequests/{requestId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUid;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.toUid;
    }

    match /conversations/{convId} {
      allow read, update: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.senderUid
          && request.resource.data.text.size() <= 500
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
    }

    match /gameInvites/{inviteId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUid;
      allow read, delete: if request.auth != null
        && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
    }

    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.reporterUid;
      allow read: if false;
    }

    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.hostUid;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.hostUid
            || request.auth.uid in resource.data.playerUids);
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.hostUid;

      match /actions/{actionId} {
        allow read, delete: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.hostUid;
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.playerUid
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.playerUids;
      }

      match /events/{eventId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.hostUid;
      }

      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.senderUid
          && request.resource.data.text.size() <= 500;
        allow delete: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.hostUid;
      }
    }
  }
}
