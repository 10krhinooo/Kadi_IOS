rules_version = '2';

// Permissive ruleset used ONLY by the Firebase Local Emulator Suite for
// `KadiOnlineTests`. Production deploys use `firestore.rules`.
//
// FirebaseAuth's keychain-backed persistence doesn't work in `swift test` on
// macOS (SecItemAdd -34018, missing keychain-sharing entitlement for
// command-line test binaries), so emulator tests can't authenticate via
// FirebaseAuth and exercise the real auth-gated rules. This ruleset allows
// unauthenticated emulator access so Firestore-layer logic (ProfileService,
// RoomService, RoomHost sync) can still be tested end-to-end.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
